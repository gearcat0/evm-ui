{
  "name": "evm-ui",
  "version": "0.1.0",
  "description": "Shared design system for EVM tooling apps (evmaddressbook, tx-builder, and future related apps)",
  "license": "MIT",
  "type": "module",
  "module": "./dist/index.es.js",
  "main": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "build": "node build.mjs"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "esbuild": "^0.24.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.6.3"
  },
  "allowScripts": {
    "esbuild@0.24.2": true
  }
}
